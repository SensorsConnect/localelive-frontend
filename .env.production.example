# Canonical template for frontend/.env.production.
# Copy to .env.production and fill with real values before running
# `docker-compose build frontend`, or populate the GitHub secret
# FRONTEND_ENV_PRODUCTION with the same content for CI builds.
#
# Every NEXT_PUBLIC_* key listed here is baked into the client JS bundle
# at build time. A missing or REPLACE_ME value fails the docker build
# (see frontend/scripts/check-prod-env.sh).

# Backend
NEXT_PUBLIC_BACKEND_URL=REPLACE_ME

# Mapbox (without this, the map fails to initialize -> mobile crash/freeze)
NEXT_PUBLIC_MAPBOX_TOKEN=REPLACE_ME

# Clerk auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=REPLACE_ME
CLERK_SECRET_KEY=REPLACE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/chat
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/chat
